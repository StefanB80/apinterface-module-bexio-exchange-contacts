<%
  const s = setup || {};
  const ctxCompanyId = (typeof formCompanyId !== 'undefined' && formCompanyId !== null && !Number.isNaN(Number(formCompanyId))) ? Number(formCompanyId) : Number(companyId);
  const err = (typeof query !== 'undefined' && query.error) ? String(query.error) : '';
  const ok = (typeof query !== 'undefined' && query.success);
  const bexioUrl = s.bexioBaseUrl || 'https://api.bexio.com';
  const ewsUrlVal = s.ewsUrl || '';
  const ewsUserVal = s.ewsUser || '';
  const exVer = s.exchangeVersion || 'Exchange2016';
  const mapping = s.fieldMapping || {};
  const defMap = s.defaultFieldMapping || {};
  const visual = (manifest && manifest.visual) ? manifest.visual : null;
  const probeBexioOk = Boolean(s.probeBexioOk);
  const probeEwsOk = Boolean(s.probeEwsOk);
  const bexioFieldList = Array.isArray(s.bexioFieldCatalog) ? s.bexioFieldCatalog : [];
  const exchangeFieldList = Array.isArray(s.exchangeFieldCatalog) ? s.exchangeFieldCatalog : [];
  const bexioEnabledSet = new Set(Array.isArray(s.bexioEnabledKeys) ? s.bexioEnabledKeys : []);
  const exchangeEnabledSet = new Set(Array.isArray(s.exchangeEnabledKeys) ? s.exchangeEnabledKeys : []);
  const protocolHistory = Array.isArray(s.protocolHistory) ? s.protocolHistory : [];
  const protocolHistoryDesc = protocolHistory.slice().reverse();

  function formatIso(value) {
    if (!value) return '';
    const d = new Date(value);
    if (Number.isNaN(d.getTime())) return String(value);
    return d.toLocaleString('de-CH');
  }
  function probeSvgTitle(isBexio) {
    if (isBexio) {
      if (probeBexioOk) {
        return 'bexio: Verbindung zuletzt erfolgreich. ' + (s.probeBexioSummary || '') + ' (' + formatIso(s.probeBexioAt) + '). Klick: Setup-Panel bexio oeffnen.';
      }
      return 'bexio: Noch kein erfolgreicher Test. «bexio testen» ausfuehren.';
    }
    if (probeEwsOk) {
      return 'Exchange: Verbindung zuletzt erfolgreich. ' + (s.probeEwsSummary || '') + ' (' + formatIso(s.probeEwsAt) + '). Klick: Setup-Panel Exchange oeffnen.';
    }
    return 'Exchange: Noch kein erfolgreicher Test. «EWS testen» ausfuehren.';
  }
  function setupAnchorForApp(appId) {
    if (appId === 'bexio') return '#bec-setup-bexio';
    if (appId === 'exchange') return '#bec-setup-exchange';
    return '#bec-setup-form';
  }
  function protocolTypeLabel(t) {
    if (t === 'test_bexio') return 'bexio-Test';
    if (t === 'test_ews') return 'EWS-Test';
    if (t === 'sync') return 'Synchronisation';
    return String(t || '—');
  }
  const enabledExchangeKeysList = exchangeFieldList.filter(function (t) { return exchangeEnabledSet.has(t.key); }).map(function (t) { return t.key; });
  const fmbBlocks = (Array.isArray(s.fieldMappingBlocks) && s.fieldMappingBlocks.length)
    ? s.fieldMappingBlocks
    : [{ id: 'block-1', title: 'Feldzuordnung 1', conditions: [], fieldMapping: mapping }];
  function blockMapComplete(blk) {
    var m = blk.fieldMapping || {};
    return enabledExchangeKeysList.length > 0 && enabledExchangeKeysList.every(function (k) { return String(m[k] || '').trim().length > 0; });
  }
  const mappingComplete = fmbBlocks.length > 0 && fmbBlocks.every(blockMapComplete);
%>
<style>
  .bec-flow-card { margin-bottom: 1rem; }
  .bec-flow-svg { width: 100%; height: auto; min-height: 480px; display: block; }
  .bec-flow-svg a { cursor: pointer; }
  .bec-flow-status { font-size: 26px; font-weight: 700; }
  .bec-flow-status--ok { fill: #1f6b33; }
  .bec-flow-status--warn { fill: #b45309; }
  .bec-panel { border: 1px solid #d7dfeb; border-radius: 10px; padding: 0 12px; margin-bottom: 12px; background: #fafbfd; }
  .bec-panel > summary { cursor: pointer; list-style: none; font-weight: 700; padding: 12px 4px; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .bec-panel > summary::-webkit-details-marker { display: none; }
  .bec-panel > summary::after { content: '▾'; font-size: 12px; color: #5e6b7c; }
  .bec-panel[open] > summary::after { content: '▴'; }
  .bec-okpill { display: inline-flex; align-items: center; gap: 4px; color: #1f6b33; font-size: 13px; font-weight: 700; }
  .bec-field-sub { margin-top: 10px; background: #fff; border: 1px dashed #c5d0e0; border-radius: 8px; padding: 0 10px 10px; }
  .bec-field-sub > summary { font-weight: 600; font-size: 14px; padding: 10px 4px; }
  /* Mindestbreite groesser: sonst zu viele Spalten, Text bricht unleserlich */
  .bec-cb-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr)); gap: 10px 14px; margin-top: 8px; }
  .bec-cb-item { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; line-height: 1.4; padding: 8px 10px; border-radius: 6px; border: 1px solid #eef2f7; background: #fcfdff; }
  /* Core setzt input 100%-Breite — hier explizit nur schmale Checkbox */
  .bec-cb-item input[type="checkbox"] {
    width: 1.125rem;
    height: 1.125rem;
    flex: 0 0 1.125rem;
    padding: 0;
    margin: 0.15rem 0 0;
    box-sizing: border-box;
  }
  /* Linksbuendig: volle Zellenbreite; globales Core-`label` per Spezifitaet uebersteuern */
  .bec-cb-grid.apiface-check-list-left {
    justify-items: stretch;
    align-items: stretch;
  }
  .bec-cb-grid.apiface-check-list-left label.bec-cb-item {
    display: flex;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    margin: 0;
    font-weight: 500;
    justify-self: stretch;
    justify-content: flex-start;
    align-items: flex-start;
    text-align: left;
  }
  .bec-cb-grid.apiface-check-list-left label.bec-cb-item > span {
    text-align: left;
    flex: 1 1 0%;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .bec-cb-grid.apiface-check-list-left label.bec-cb-item > span small {
    text-align: left;
  }
  /* Schmale Spalten, grosser Zwischenraum fuer Verbindungslinien */
  .bec-map-wrap {
    display: grid;
    grid-template-columns: minmax(180px, 16.5rem) minmax(180px, 16.5rem);
    justify-content: space-between;
    column-gap: clamp(28px, 10vw, 140px);
    row-gap: 20px;
    position: relative;
    min-height: 400px;
    margin-top: 12px;
  }
  .bec-map-svg-layer { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; overflow: visible; }
  .bec-map-col { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 8px; max-width: 16.5rem; width: 100%; }
  .bec-map-col h4 { margin: 0 0 6px; font-size: 13px; color: #5e6b7c; text-transform: uppercase; letter-spacing: 0.02em; }
  .bec-map-item {
    border: 1px solid #d7dfeb;
    border-radius: 8px;
    padding: 8px 10px;
    background: #fff;
    cursor: pointer;
    text-align: left;
    font: inherit;
    width: 100%;
    box-sizing: border-box;
    transition: box-shadow 0.12s ease, border-color 0.12s ease;
    color: #111827;
  }
  .bec-map-item:hover { border-color: #245dff; box-shadow: 0 2px 8px rgba(36, 93, 255, 0.12); }
  /* Erste Wahl: entweder Exchange-Ziel oder bexio-Quelle — jeweils zweites Feld antippen */
  .bec-map-item.is-picked,
  .bec-map-item.is-picked-src {
    outline: none;
    border: 2px solid #d97706;
    box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.22);
    background: #fffbeb;
  }
  /* Kurz nach zweiter Wahl (Zuordnung ausloesen) */
  .bec-map-item.is-flash-tgt,
  .bec-map-item.is-flash-src {
    border: 2px solid #059669;
    box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.22);
    background: #ecfdf5;
  }
  .bec-map-item.is-mapped { border-color: #8eb0ff; background: #f5f8ff; }
  .bec-map-item.is-disabled { opacity: 0.45; pointer-events: none; }
  .bec-map-item:disabled {
    opacity: 1;
    cursor: not-allowed;
    background: #f9fafb;
    color: #4b5563;
    border-color: #e5e7eb;
  }
  .bec-map-primary {
    display: block;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    color: #0f172a;
    letter-spacing: 0.01em;
  }
  .bec-map-primary code {
    font-family: ui-monospace, Consolas, monospace;
    font-size: 0.95em;
    font-weight: 700;
    background: transparent;
    color: inherit;
  }
  .bec-map-secondary {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: #475569;
    margin-top: 4px;
    line-height: 1.35;
  }
  .bec-map-mapline {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #1d4ed8;
    margin-top: 6px;
    font-family: ui-monospace, Consolas, monospace;
  }
  .bec-fmb-root { display: flex; flex-direction: column; gap: 20px; }
  .bec-fmb-block { border: 1px solid #d7dfeb; border-radius: 10px; padding: 12px; background: #fafbfd; }
  .bec-fmb-head { margin-bottom: 10px; }
  .bec-fmb-head-label { font-size: 12px; color: #5e6b7c; display: block; margin-bottom: 4px; }
  .bec-fmb-title-input { max-width: 420px; font-weight: 700; padding: 8px 10px; border-radius: 8px; border: 1px solid #bcc7d6; }
  .bec-cond-wrap { margin-bottom: 12px; }
  .bec-cond-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 6px; }
  .bec-cond-table th, .bec-cond-table td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #eef2f7; vertical-align: middle; }
  .bec-cond-table th { background: #f8fafc; font-weight: 700; }
  .bec-cond-th-join { width: 5.5rem; }
  .bec-cond-th-actions { width: 3rem; }
  .bec-cond-table select, .bec-cond-table input { width: 100%; box-sizing: border-box; padding: 6px 8px; font-size: 13px; }
  .bec-map-fold { margin: 0; border: 0; padding: 0; }
  .bec-map-fold > summary { cursor: pointer; font-weight: 600; font-size: 13px; color: #374151; padding: 6px 0; list-style: none; }
  .bec-map-fold > summary::-webkit-details-marker { display: none; }
  .bec-map-fold > summary::after { content: ' ▾'; font-size: 11px; color: #6b7280; }
  .bec-map-fold[open] > summary::after { content: ' ▴'; }
  .bec-map-hint { font-size: 13px; color: #5e6b7c; margin: 0 0 10px; max-width: 920px; }
  .bec-map-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .bec-proto-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .bec-proto-table th, .bec-proto-table td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #eef2f7; vertical-align: top; }
  .bec-proto-table th { background: #f8fafc; }
  .bec-proto-pre { white-space: pre-wrap; font-size: 12px; max-height: 240px; overflow: auto; background: #f8fafc; padding: 10px; border-radius: 8px; margin-top: 8px; }
</style>
<div class="grid-1">
  <% if (err) { %><div class="alert"><%= err %></div><% } %>
  <% if (ok) { %><div class="alert ok" data-auto-dismiss="1">Aktion erfolgreich ausgefuehrt.</div><% } %>

  <div class="card bec-flow-card">
    <h2>Datenstroeme</h2>
    <% if (visual && visual.circle && Array.isArray(visual.apps)) { %>
      <svg class="bec-flow-svg" viewBox="0 0 1200 680" aria-label="Modul-Datenfluss">
        <defs>
          <marker id="bec-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" fill="#2f4fb3"></path>
          </marker>
        </defs>
        <circle cx="<%= visual.circle.center.x %>" cy="<%= visual.circle.center.y %>" r="<%= visual.circle.radius %>" fill="none" stroke="#6379d8" stroke-width="2.5" stroke-dasharray="12 12"></circle>
        <% visual.apps.forEach(function(app) { %>
          <% const isBexio = app.id === 'bexio'; const stOk = isBexio ? probeBexioOk : probeEwsOk; %>
          <g>
            <a href="<%= setupAnchorForApp(app.id) %>" tabindex="0" class="bec-flow-setup-link">
              <title><%= probeSvgTitle(isBexio) %></title>
              <circle cx="<%= app.position.x %>" cy="<%= app.position.y %>" r="48" fill="#e9efff" stroke="#2f4fb3" stroke-width="3"></circle>
              <text class="bec-flow-status <%= stOk ? 'bec-flow-status--ok' : 'bec-flow-status--warn' %>" x="<%= app.position.x + 62 %>" y="<%= app.position.y + 10 %>" text-anchor="start"><%= stOk ? '✓' : '!' %></text>
            </a>
            <text x="<%= app.position.x %>" y="<%= app.position.y + 82 %>" text-anchor="middle" fill="#1a2340" font-size="17" font-weight="700"><%= app.label %></text>
          </g>
        <% }); %>
        <% (visual.dataStreams || []).forEach(function(stream) { %>
          <% const src = visual.apps.find(function(a) { return a.id === stream.source; }); const tgt = visual.apps.find(function(a) { return a.id === stream.target; }); %>
          <% if (src && tgt) { %>
            <g>
              <line x1="<%= src.position.x %>" y1="<%= src.position.y %>" x2="<%= tgt.position.x %>" y2="<%= tgt.position.y %>" stroke="#2f4fb3" stroke-width="3" marker-end="url(#bec-arrow)"></line>
              <text x="<%= stream.midpoint.x %>" y="<%= stream.midpoint.y %>" text-anchor="middle" fill="#27418f" font-size="14" font-weight="600"><%= stream.label %></text>
            </g>
          <% } %>
        <% }); %>
        <text x="<%= visual.circle.center.x %>" y="<%= visual.circle.center.y %>" text-anchor="middle" fill="#1a2340" font-size="20" font-weight="700">Kontaktsync</text>
      </svg>
      <p class="muted" style="font-size:13px;margin-top:10px;">Kreise: Hover zeigt Status-Tooltip, Klick oeffnet das zugehoerige Setup (bexio / Exchange). Die <a href="#bec-protocol-list">Protokollliste</a> ist unten.</p>
    <% } else { %>
      <p class="muted">Keine Visualisierung im Manifest.</p>
    <% } %>
  </div>

  <div class="card">
    <h2>Setup</h2>
    <form method="post" action="<%= modulePath %>/setup" class="grid-1" autocomplete="on" id="bec-setup-form">
      <input type="hidden" name="setupCompanyId" value="<%= ctxCompanyId %>">
      <input type="hidden" name="fieldMappingBlocksJson" id="bec-fmb-json" value="">

      <details id="bec-setup-bexio" class="bec-panel" <%= probeBexioOk ? '' : 'open' %>>
        <summary>
          <span>bexio</span>
          <% if (probeBexioOk) { %>
            <span class="bec-okpill" title="Letzter Test: <%= formatIso(s.probeBexioAt) %>">OK ✓</span>
          <% } else { %>
            <span class="muted" style="font-weight:600;">Prüfen</span>
          <% } %>
        </summary>
        <div style="padding: 0 4px 12px;">
          <label for="bexioBaseUrl">API Basis-URL</label>
          <input id="bexioBaseUrl" name="bexioBaseUrl" type="url" value="<%= bexioUrl %>" placeholder="https://api.bexio.com" required>
          <label for="bexioToken">Persoenlicher API-Token</label>
          <input id="bexioToken" name="bexioToken" type="password" value="" autocomplete="off" placeholder="<%= s.bexioTokenMasked ? '(gesetzt, ' + s.bexioTokenMasked + ')' : (s.bexioTokenSet ? '(gesetzt)' : 'Token einfuegen') %>">

          <details class="bec-field-sub" open>
            <summary>Kontaktfelder (bexio API) — für Zuordnung und Übernahme aktivieren</summary>
            <div class="bec-cb-grid apiface-check-list-left">
              <% bexioFieldList.forEach(function(f) { %>
                <label class="bec-cb-item">
                  <input type="checkbox" name="bexioEnabled" value="<%= f.key %>" <%= bexioEnabledSet.has(f.key) ? 'checked' : '' %>>
                  <span><%= f.label %> <small class="muted">(<%= f.key %>)</small></span>
                </label>
              <% }); %>
            </div>
          </details>

          <div class="row-actions" style="gap:.5rem;">
            <button type="submit" name="action" value="test_bexio" class="button secondary small">bexio testen</button>
          </div>
        </div>
      </details>

      <details id="bec-setup-exchange" class="bec-panel" <%= probeEwsOk ? '' : 'open' %>>
        <summary>
          <span>Exchange (EWS)</span>
          <% if (probeEwsOk) { %>
            <span class="bec-okpill" title="Letzter Test: <%= formatIso(s.probeEwsAt) %>">OK ✓</span>
          <% } else { %>
            <span class="muted" style="font-weight:600;">Prüfen</span>
          <% } %>
        </summary>
        <div style="padding: 0 4px 12px;">
          <label for="ewsUrl">EWS Endpoint</label>
          <input id="ewsUrl" name="ewsUrl" type="url" value="<%= ewsUrlVal %>" placeholder="https://mail.example.com/EWS/Exchange.asmx" required>
          <label for="ewsUser">Benutzer (z. B. DOMAIN\\user oder UPN)</label>
          <input id="ewsUser" name="ewsUser" type="text" value="<%= ewsUserVal %>" autocomplete="username" required>
          <label for="ewsPassword">Passwort</label>
          <input id="ewsPassword" name="ewsPassword" type="password" value="" autocomplete="current-password" placeholder="<%= s.ewsPasswordSet ? '(unveraendert lassen)' : 'Passwort' %>">
          <label for="exchangeVersion">Exchange-Version (EWS)</label>
          <select id="exchangeVersion" name="exchangeVersion">
            <% ['Exchange2016','Exchange2013_SP1','Exchange2013','Exchange2015','Exchange2010_SP2'].forEach(function(v) { %>
              <option value="<%= v %>" <%= exVer === v ? 'selected' : '' %>><%= v %></option>
            <% }); %>
          </select>

          <details class="bec-field-sub" open>
            <summary>Kontaktfelder (Exchange) — in die Synchronisation einbeziehen</summary>
            <div class="bec-cb-grid apiface-check-list-left">
              <% exchangeFieldList.forEach(function(f) { %>
                <label class="bec-cb-item">
                  <input type="checkbox" name="exchangeEnabled" value="<%= f.key %>" <%= exchangeEnabledSet.has(f.key) ? 'checked' : '' %>>
                  <span><%= f.label %> <small class="muted">(<%= f.key %>)</small></span>
                </label>
              <% }); %>
            </div>
          </details>

          <div class="row-actions" style="gap:.5rem;">
            <button type="submit" name="action" value="test_ews" class="button secondary small">EWS testen</button>
          </div>
        </div>
      </details>

      <details class="bec-panel" <%= (probeBexioOk && probeEwsOk && mappingComplete) ? '' : 'open' %>>
        <summary>
          <span>Feldzuordnung bexio → Exchange</span>
          <% if (mappingComplete) { %>
            <span class="bec-okpill">OK ✓</span>
          <% } else { %>
            <span class="muted" style="font-weight:600;">Zuordnen</span>
          <% } %>
        </summary>
        <div style="padding: 0 4px 12px;">
          <p class="bec-map-hint">Pro Abschnitt: optional Bedingungen (bexio-Felder), dann Zuordnung. Zuerst ein Feld antippen (links oder rechts), dann das Gegenstück. <strong>Reihenfolge der Abschnitte:</strong> Der erste Abschnitt, dessen Bedingungen zum Kontakt passen, bestimmt die Zuordnung; ohne erfüllbare Bedingung gilt ein Abschnitt ohne Bedingungszeilen bzw. der letzte Fallback.</p>
          <div class="bec-fmb-root" id="bec-fmb-root">
            <% fmbBlocks.forEach(function(block, bi) { %>
              <% var blkMap = block.fieldMapping || {}; %>
              <% var condRows = (block.conditions && block.conditions.length) ? block.conditions : [{ field: '', op: 'eq', value: '' }]; %>
              <section class="bec-fmb-block" data-block-index="<%= bi %>">
                <div class="bec-fmb-head">
                  <label class="bec-fmb-head-label" for="bec_fmb_title_<%= bi %>">Abschnitt</label>
                  <input type="text" id="bec_fmb_title_<%= bi %>" class="bec-fmb-title-input" aria-label="Abschnittstitel" value="<%= block.title || ('Feldzuordnung ' + (bi + 1)) %>" data-role="title" />
                </div>
                <div class="bec-cond-wrap">
                  <p class="muted" style="font-size:12px;margin:0 0 4px;">Bedingungen (optional — leer = gilt immer)</p>
                  <table class="bec-cond-table" data-role="cond-table">
                    <thead>
                      <tr>
                        <th class="bec-cond-th-join">und / oder</th>
                        <th>Feld (bexio)</th>
                        <th>Operator</th>
                        <th>Wert</th>
                        <th class="bec-cond-th-actions"></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% condRows.forEach(function(row, ri) { %>
                        <tr>
                          <td>
                            <% if (ri === 0) { %>
                              <span class="muted">—</span>
                            <% } else { %>
                              <select class="bec-cond-join" aria-label="Verknuepfung">
                                <option value="and" <%= (row.join !== 'or') ? 'selected' : '' %>>und</option>
                                <option value="or" <%= (row.join === 'or') ? 'selected' : '' %>>oder</option>
                              </select>
                            <% } %>
                          </td>
                          <td>
                            <select class="bec-cond-field">
                              <option value="">—</option>
                              <% bexioFieldList.forEach(function(bf) { %>
                                <option value="<%= bf.key %>" <%= (row.field === bf.key) ? 'selected' : '' %>><%= bf.key %></option>
                              <% }); %>
                            </select>
                          </td>
                          <td>
                            <select class="bec-cond-op">
                              <option value="gt" <%= (row.op || 'eq') === 'gt' ? 'selected' : '' %>>groesser</option>
                              <option value="gte" <%= (row.op || 'eq') === 'gte' ? 'selected' : '' %>>groesser gleich</option>
                              <option value="lt" <%= (row.op || 'eq') === 'lt' ? 'selected' : '' %>>kleiner</option>
                              <option value="lte" <%= (row.op || 'eq') === 'lte' ? 'selected' : '' %>>kleiner gleich</option>
                              <option value="eq" <%= (row.op || 'eq') === 'eq' ? 'selected' : '' %>>gleich</option>
                              <option value="ne" <%= (row.op || 'eq') === 'ne' ? 'selected' : '' %>>nicht gleich</option>
                              <option value="contains" <%= (row.op || 'eq') === 'contains' ? 'selected' : '' %>>enthaelt</option>
                            </select>
                          </td>
                          <td><input type="text" class="bec-cond-val" value="<%= row.value != null ? row.value : '' %>" placeholder="Zahl oder Text" /></td>
                          <td><button type="button" class="button secondary small bec-cond-del" <%= condRows.length > 1 ? '' : 'disabled' %>>−</button></td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                  <button type="button" class="button secondary small bec-cond-add" style="margin-top:8px;">+ Bedingungszeile</button>
                </div>
                <div class="bec-map-wrap" id="bec-map-wrap-<%= bi %>" data-bec-block-index="<%= bi %>">
                  <svg class="bec-map-svg-layer" id="bec-map-svg-<%= bi %>" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"></svg>
                  <details class="bec-map-fold" open>
                    <summary>bexio (Quelle) ein-/ausblenden</summary>
                    <div class="bec-map-col">
                      <h4>bexio (Quelle)</h4>
                      <% bexioFieldList.forEach(function(f) { %>
                        <button type="button" class="bec-map-item bec-map-src <%= bexioEnabledSet.has(f.key) ? '' : 'is-disabled' %>" data-bec-src="<%= f.key %>">
                          <span class="bec-map-primary"><code><%= f.key %></code></span>
                          <% var bxSub = ''; if (f.synthetic && f.label) { bxSub = String(f.label); } else if (f.label && String(f.label).trim() && f.label !== f.key) { bxSub = String(f.label).trim(); } %>
                          <% if (bxSub) { %><span class="bec-map-secondary"><%= bxSub %></span><% } %>
                        </button>
                      <% }); %>
                    </div>
                  </details>
                  <details class="bec-map-fold" open>
                    <summary>Exchange (Ziel) ein-/ausblenden</summary>
                    <div class="bec-map-col">
                      <h4>Exchange (Ziel)</h4>
                      <% exchangeFieldList.forEach(function(t) { %>
                        <% var exMain = (t.ewsId && String(t.ewsId).trim()) ? String(t.ewsId).trim() : (t.label || t.key || ''); %>
                        <% var exSub = (t.label && String(t.label).trim() && t.label !== exMain) ? String(t.label).trim() : ''; %>
                        <button type="button" class="bec-map-item bec-map-tgt <%= exchangeEnabledSet.has(t.key) ? '' : 'is-disabled' %>" data-bec-tgt="<%= t.key %>" <%= exchangeEnabledSet.has(t.key) ? '' : 'disabled' %>>
                          <span class="bec-map-primary"><%= exMain %></span>
                          <% if (exSub) { %><span class="bec-map-secondary"><%= exSub %></span><% } %>
                          <span class="bec-map-mapline" id="bec_tgt_hint_<%= bi %>_<%= t.key %>">← <%= (blkMap[t.key] || '—') %></span>
                        </button>
                      <% }); %>
                    </div>
                  </details>
                </div>
              </section>
            <% }); %>
          </div>
          <button type="button" class="button secondary" id="bec-fmb-add-block" style="margin-top:12px;">+ Weitere Feldzuordnung</button>
          <div class="bec-map-actions">
            <button type="button" class="button secondary small" id="bec-map-reset-all">Standard-Zuordnung (alle Abschnitte)</button>
          </div>
        </div>
      </details>

      <div class="row-actions" style="margin-top:1rem;gap:.5rem;">
        <button type="submit" name="action" value="save" class="button">Speichern</button>
        <button type="submit" name="action" value="sync" class="button">Jetzt synchronisieren</button>
      </div>
    </form>
    <% if (manifest && manifest.version) { %>
      <p class="muted" style="margin-top:1rem;">Modulversion <%= manifest.version %><% if (s.moduleVersion) { %> · Paket <%= s.moduleVersion %><% } %></p>
    <% } %>
  </div>

  <div class="card" id="bec-protocol-list">
    <h2>Protokollliste</h2>
    <p class="muted" style="margin-top:0;">Gespeicherte Läufe (Tests und Synchronisation). «Anzeigen» klappt den Text auf, «Download» speicht eine Textdatei.</p>
    <% if (!protocolHistoryDesc.length) { %>
      <p class="muted">Noch keine Einträge. Nach einem Test oder einer Synchronisation erscheinen Protokolle hier.</p>
    <% } else { %>
      <table class="bec-proto-table">
        <thead>
          <tr>
            <th>Zeit</th>
            <th>Typ</th>
            <th>Kurztext</th>
            <th>Aktionen</th>
          </tr>
        </thead>
        <tbody>
          <% protocolHistoryDesc.forEach(function(row) { %>
            <tr>
              <td><%= formatIso(row.at) %></td>
              <td><%= protocolTypeLabel(row.type) %></td>
              <td><%= row.summary || '—' %></td>
              <td>
                <details>
                  <summary class="button secondary small" style="display:inline-block;margin:0;cursor:pointer;">Anzeigen</summary>
                  <div class="bec-proto-pre"><%= row.log || '—' %></div>
                </details>
                <button type="button" class="button secondary small bec-dl-btn" data-id="<%= row.id %>">Download</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>
<script type="application/json" id="bec-protocol-json"><%- JSON.stringify(protocolHistoryDesc) %></script>
<script type="application/json" id="bec-default-map"><%- JSON.stringify(defMap) %></script>
<script type="application/json" id="bec-fmb-initial-json"><%- JSON.stringify(fmbBlocks) %></script>
<script>
(function () {
  function openBecSetupPanel(id) {
    var el = document.getElementById(id);
    if (!el || el.tagName !== 'DETAILS') return;
    el.open = true;
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
  function fromHash(hash) {
    if (!hash || hash.length < 2) return;
    var id = hash.slice(1);
    if (id === 'bec-setup-bexio' || id === 'bec-setup-exchange') {
      openBecSetupPanel(id);
    }
  }
  document.querySelectorAll('a.bec-flow-setup-link').forEach(function (a) {
    a.addEventListener('click', function () {
      var href = a.getAttribute('href') || '';
      if (href.indexOf('#bec-setup-') !== 0) return;
      openBecSetupPanel(href.slice(1));
    });
  });
  window.addEventListener('hashchange', function () { fromHash(location.hash); });
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { fromHash(location.hash); });
  } else {
    fromHash(location.hash);
  }
})();

(function () {
  var root = document.getElementById('bec-fmb-root');
  if (!root) return;

  var defNode = document.getElementById('bec-default-map');
  var initNode = document.getElementById('bec-fmb-initial-json');
  var jsonOut = document.getElementById('bec-fmb-json');
  var form = document.getElementById('bec-setup-form');
  var defMap = {};
  try {
    defMap = JSON.parse((defNode && defNode.textContent) || '{}');
  } catch (e1) {
    defMap = {};
  }

  var state = { blocks: [] };
  try {
    var raw = (initNode && initNode.textContent) || '[]';
    var parsed = JSON.parse(raw);
    state.blocks = Array.isArray(parsed) ? parsed : [parsed];
  } catch (e2) {
    state.blocks = [];
  }
  if (!state.blocks.length) {
    state.blocks = [{ id: 'block-1', title: 'Feldzuordnung 1', conditions: [], fieldMapping: {} }];
  }
  state.blocks.forEach(function (b, i) {
    if (!b.fieldMapping) b.fieldMapping = {};
    if (!b.id) b.id = 'block-' + (i + 1);
    if (!b.title) b.title = 'Feldzuordnung ' + (i + 1);
    if (!Array.isArray(b.conditions)) b.conditions = [];
  });

  var mapRefreshers = [];

  function ns() {
    return 'http://www.w3.org/2000/svg';
  }

  function ensureMapArrowMarker(svg, bi) {
    var mid = 'bec-map-arrowhead-' + bi;
    if (svg.querySelector('#' + mid)) return mid;
    var defs = document.createElementNS(ns(), 'defs');
    var marker = document.createElementNS(ns(), 'marker');
    marker.setAttribute('id', mid);
    marker.setAttribute('viewBox', '0 0 10 10');
    marker.setAttribute('refX', '9');
    marker.setAttribute('refY', '5');
    marker.setAttribute('markerWidth', '7');
    marker.setAttribute('markerHeight', '7');
    marker.setAttribute('orient', 'auto-start-reverse');
    var mpath = document.createElementNS(ns(), 'path');
    mpath.setAttribute('d', 'M 0 0 L 10 5 L 0 10 z');
    mpath.setAttribute('fill', '#2563eb');
    marker.appendChild(mpath);
    defs.appendChild(marker);
    svg.insertBefore(defs, svg.firstChild);
    return mid;
  }

  function readMap(bi, tgtKey) {
    var b = state.blocks[bi];
    if (!b || !b.fieldMapping) return '';
    return String(b.fieldMapping[tgtKey] || '').trim();
  }

  function setMap(bi, tgtKey, srcKey) {
    if (!state.blocks[bi]) return;
    if (!state.blocks[bi].fieldMapping) state.blocks[bi].fieldMapping = {};
    state.blocks[bi].fieldMapping[tgtKey] = srcKey || '';
    var hint = document.getElementById('bec_tgt_hint_' + bi + '_' + tgtKey);
    if (hint) hint.textContent = '\u2190 ' + (srcKey || '\u2014');
  }

  function clearMapPathsOnly(svg) {
    Array.prototype.slice.call(svg.childNodes).forEach(function (node) {
      if (node.nodeName === 'path') svg.removeChild(node);
    });
  }

  function initOneBlock(wrap, bi) {
    var svg = document.getElementById('bec-map-svg-' + bi);
    if (!wrap || !svg) return;

    var pickedTgt = null;
    var pickedSrc = null;
    var markerId = ensureMapArrowMarker(svg, bi);
    var markerUrl = 'url(#' + markerId + ')';

    function redrawLines() {
      clearMapPathsOnly(svg);
      var w = wrap.clientWidth;
      var h = wrap.clientHeight;
      if (w < 2 || h < 2) return;
      svg.setAttribute('viewBox', '0 0 ' + w + ' ' + h);

      wrap.querySelectorAll('.bec-map-tgt:not([disabled])').forEach(function (btn) {
        var tgtKey = btn.getAttribute('data-bec-tgt');
        var srcKey = readMap(bi, tgtKey);
        if (!srcKey) return;
        var srcEl = wrap.querySelector('.bec-map-src[data-bec-src="' + srcKey + '"]:not(.is-disabled)');
        if (!srcEl || !btn) return;
        var wr = wrap.getBoundingClientRect();
        var a = srcEl.getBoundingClientRect();
        var b = btn.getBoundingClientRect();
        var x1 = a.right - wr.left;
        var y1 = a.top + a.height / 2 - wr.top;
        var x2 = b.left - wr.left;
        var y2 = b.top + b.height / 2 - wr.top;
        var mid = (x1 + x2) / 2;
        var d = 'M ' + x1 + ' ' + y1 + ' C ' + mid + ' ' + y1 + ', ' + mid + ' ' + y2 + ', ' + x2 + ' ' + y2;
        var path = document.createElementNS(ns(), 'path');
        path.setAttribute('d', d);
        path.setAttribute('stroke', '#2f4fb3');
        path.setAttribute('stroke-width', '2');
        path.setAttribute('fill', 'none');
        path.setAttribute('opacity', '0.85');
        path.setAttribute('marker-end', markerUrl);
        svg.appendChild(path);
      });
    }

    function drawFlashArrowOrdered(firstEl, secondEl, onDone) {
      var w = wrap.clientWidth;
      var h = wrap.clientHeight;
      if (w < 2 || h < 2) {
        if (onDone) onDone();
        return;
      }
      svg.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
      ensureMapArrowMarker(svg, bi);
      var wr = wrap.getBoundingClientRect();
      var r1 = firstEl.getBoundingClientRect();
      var r2 = secondEl.getBoundingClientRect();
      var cx1 = r1.left + r1.width / 2;
      var cx2 = r2.left + r2.width / 2;
      var x1;
      var y1;
      var x2;
      var y2;
      if (cx1 <= cx2) {
        x1 = r1.right - wr.left;
        y1 = r1.top + r1.height / 2 - wr.top;
        x2 = r2.left - wr.left;
        y2 = r2.top + r2.height / 2 - wr.top;
      } else {
        x1 = r1.left - wr.left;
        y1 = r1.top + r1.height / 2 - wr.top;
        x2 = r2.right - wr.left;
        y2 = r2.top + r2.height / 2 - wr.top;
      }
      var mid = (x1 + x2) / 2;
      var d = 'M ' + x1 + ' ' + y1 + ' C ' + mid + ' ' + y1 + ', ' + mid + ' ' + y2 + ', ' + x2 + ' ' + y2;
      var path = document.createElementNS(ns(), 'path');
      path.setAttribute('id', 'bec-map-flash-path-' + bi);
      path.setAttribute('d', d);
      path.setAttribute('stroke', '#2563eb');
      path.setAttribute('stroke-width', '3');
      path.setAttribute('fill', 'none');
      path.setAttribute('marker-end', markerUrl);
      path.setAttribute('opacity', '1');
      svg.appendChild(path);
      setTimeout(function () {
        var fp = svg.querySelector('#bec-map-flash-path-' + bi);
        if (fp) fp.remove();
        if (onDone) onDone();
      }, 520);
    }

    function updateMappedClasses() {
      wrap.querySelectorAll('.bec-map-src').forEach(function (el) {
        el.classList.remove('is-mapped');
      });
      wrap.querySelectorAll('.bec-map-tgt').forEach(function (el) {
        el.classList.remove('is-mapped');
        if (el.disabled) return;
        var tgtKey = el.getAttribute('data-bec-tgt');
        if (readMap(bi, tgtKey)) el.classList.add('is-mapped');
      });
      wrap.querySelectorAll('.bec-map-tgt:not([disabled])').forEach(function (el) {
        var tgtKey = el.getAttribute('data-bec-tgt');
        var sk = readMap(bi, tgtKey);
        if (!sk) return;
        var srcEl = wrap.querySelector('.bec-map-src[data-bec-src="' + sk + '"]');
        if (srcEl && !srcEl.classList.contains('is-disabled')) srcEl.classList.add('is-mapped');
      });
    }

    function refresh() {
      updateMappedClasses();
      redrawLines();
    }

    wrap.querySelectorAll('.bec-map-tgt:not([disabled])').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var k = btn.getAttribute('data-bec-tgt');
        if (pickedSrc) {
          var srcBtn0 = wrap.querySelector('.bec-map-src[data-bec-src="' + pickedSrc + '"]:not(.is-disabled)');
          if (!srcBtn0) {
            pickedSrc = null;
            wrap.querySelectorAll('.bec-map-src').forEach(function (b) {
              b.classList.remove('is-picked-src');
            });
            return;
          }
          var skDone = pickedSrc;
          pickedSrc = null;
          wrap.querySelectorAll('.bec-map-src').forEach(function (b) {
            b.classList.remove('is-picked-src');
          });
          wrap.querySelectorAll('.bec-map-item').forEach(function (b) {
            b.classList.remove('is-flash-src', 'is-flash-tgt');
          });
          srcBtn0.classList.add('is-flash-src');
          btn.classList.add('is-flash-tgt');
          drawFlashArrowOrdered(srcBtn0, btn, function () {
            setMap(bi, k, skDone);
            wrap.querySelectorAll('.bec-map-item').forEach(function (b) {
              b.classList.remove('is-picked', 'is-picked-src', 'is-flash-src', 'is-flash-tgt');
            });
            pickedTgt = null;
            refresh();
          });
          return;
        }
        if (pickedTgt === k) {
          pickedTgt = null;
          wrap.querySelectorAll('.bec-map-tgt').forEach(function (b) {
            b.classList.remove('is-picked');
          });
          return;
        }
        pickedTgt = k;
        pickedSrc = null;
        wrap.querySelectorAll('.bec-map-tgt').forEach(function (b) {
          b.classList.remove('is-picked');
        });
        wrap.querySelectorAll('.bec-map-src').forEach(function (b) {
          b.classList.remove('is-picked-src');
        });
        btn.classList.add('is-picked');
      });
    });

    wrap.querySelectorAll('.bec-map-src:not(.is-disabled)').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var sk = btn.getAttribute('data-bec-src');
        if (pickedTgt) {
          var tgtBtn0 = wrap.querySelector('.bec-map-tgt[data-bec-tgt="' + pickedTgt + '"]');
          if (!tgtBtn0 || tgtBtn0.disabled) return;
          var kDone = pickedTgt;
          pickedTgt = null;
          wrap.querySelectorAll('.bec-map-tgt').forEach(function (b) {
            b.classList.remove('is-picked');
          });
          wrap.querySelectorAll('.bec-map-item').forEach(function (b) {
            b.classList.remove('is-flash-src', 'is-flash-tgt');
          });
          tgtBtn0.classList.add('is-flash-tgt');
          btn.classList.add('is-flash-src');
          drawFlashArrowOrdered(tgtBtn0, btn, function () {
            setMap(bi, kDone, sk);
            wrap.querySelectorAll('.bec-map-item').forEach(function (b) {
              b.classList.remove('is-picked', 'is-picked-src', 'is-flash-src', 'is-flash-tgt');
            });
            pickedSrc = null;
            refresh();
          });
          return;
        }
        if (pickedSrc === sk) {
          pickedSrc = null;
          wrap.querySelectorAll('.bec-map-src').forEach(function (b) {
            b.classList.remove('is-picked-src');
          });
          return;
        }
        pickedSrc = sk;
        pickedTgt = null;
        wrap.querySelectorAll('.bec-map-src').forEach(function (b) {
          b.classList.remove('is-picked-src');
        });
        wrap.querySelectorAll('.bec-map-tgt').forEach(function (b) {
          b.classList.remove('is-picked');
        });
        btn.classList.add('is-picked-src');
      });
    });

    window.addEventListener('resize', redrawLines);
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(function () {
        refresh();
      });
    }
    refresh();
    setTimeout(refresh, 120);
    mapRefreshers[bi] = refresh;
  }

  function collectConditionsFromTable(table) {
    if (!table) return [];
    var rows = [];
    table.querySelectorAll('tbody tr').forEach(function (tr, ri) {
      var joinSel = tr.querySelector('.bec-cond-join');
      var field = tr.querySelector('.bec-cond-field');
      var op = tr.querySelector('.bec-cond-op');
      var val = tr.querySelector('.bec-cond-val');
      var o = {
        field: field ? String(field.value || '').trim() : '',
        op: op ? String(op.value || 'eq') : 'eq',
        value: val ? String(val.value || '') : ''
      };
      if (ri > 0 && joinSel) {
        o.join = joinSel.value === 'or' ? 'or' : 'and';
      }
      rows.push(o);
    });
    return rows;
  }

  function serializeFmb() {
    var blocks = [];
    root.querySelectorAll('.bec-fmb-block').forEach(function (sec, idx) {
      var bi = Number(sec.getAttribute('data-block-index'));
      if (Number.isNaN(bi)) bi = idx;
      var titleIn = sec.querySelector('[data-role="title"]');
      var title = titleIn ? titleIn.value.trim() : 'Feldzuordnung ' + (idx + 1);
      var tbl = sec.querySelector('[data-role="cond-table"]');
      var conds = collectConditionsFromTable(tbl);
      var prev = state.blocks[bi] || {};
      var fmSrc = (prev.fieldMapping && typeof prev.fieldMapping === 'object') ? prev.fieldMapping : {};
      blocks.push({
        id: prev.id || 'block-' + (idx + 1),
        title: title,
        conditions: conds,
        fieldMapping: JSON.parse(JSON.stringify(fmSrc))
      });
    });
    return blocks;
  }

  function wireConditionUi(sec) {
    var tbl = sec.querySelector('[data-role="cond-table"]');
    if (!tbl) return;
    var tbody = tbl.querySelector('tbody');
    function addRow() {
      var tr = document.createElement('tr');
      tr.innerHTML =
        '<td><select class="bec-cond-join" aria-label="Verknuepfung">' +
        '<option value="and">und</option><option value="or">oder</option></select></td>' +
        '<td><select class="bec-cond-field">' +
        tbl.querySelector('.bec-cond-field').innerHTML +
        '</select></td>' +
        '<td><select class="bec-cond-op">' +
        tbl.querySelector('.bec-cond-op').innerHTML +
        '</select></td>' +
        '<td><input type="text" class="bec-cond-val" placeholder="Zahl oder Text" /></td>' +
        '<td><button type="button" class="button secondary small bec-cond-del">−</button></td>';
      tbody.appendChild(tr);
      tr.querySelector('.bec-cond-del').addEventListener('click', function () {
        if (tbody.querySelectorAll('tr').length <= 1) return;
        tr.remove();
        syncDelButtons();
      });
      syncDelButtons();
    }
    function syncDelButtons() {
      var trs = tbody.querySelectorAll('tr');
      trs.forEach(function (tr, i) {
        var del = tr.querySelector('.bec-cond-del');
        if (del) del.disabled = trs.length <= 1;
        var join = tr.querySelector('.bec-cond-join');
        if (join) {
          join.style.visibility = i === 0 ? 'hidden' : 'visible';
        }
      });
    }
    sec.querySelectorAll('.bec-cond-add').forEach(function (btn) {
      btn.addEventListener('click', addRow);
    });
    sec.querySelectorAll('.bec-cond-del').forEach(function (del) {
      del.addEventListener('click', function () {
        var tr = del.closest('tr');
        if (!tr || tbody.querySelectorAll('tr').length <= 1) return;
        tr.remove();
        syncDelButtons();
      });
    });
    syncDelButtons();
  }

  root.querySelectorAll('.bec-fmb-block').forEach(function (sec) {
    var bi = Number(sec.getAttribute('data-block-index'));
    wireConditionUi(sec);
    var wrap = sec.querySelector('.bec-map-wrap');
    if (wrap) initOneBlock(wrap, bi);
  });

  var addBtn = document.getElementById('bec-fmb-add-block');
  if (addBtn) {
    addBtn.addEventListener('click', function () {
      var first = root.querySelector('.bec-fmb-block');
      if (!first) return;
      var clone = first.cloneNode(true);
      var n = root.querySelectorAll('.bec-fmb-block').length;
      clone.setAttribute('data-block-index', String(n));
      clone.querySelectorAll('[id^="bec_fmb_title_"]').forEach(function (el) {
        el.id = 'bec_fmb_title_' + n;
      });
      clone.querySelectorAll('.bec-map-wrap').forEach(function (w) {
        w.id = 'bec-map-wrap-' + n;
        w.setAttribute('data-bec-block-index', String(n));
      });
      clone.querySelectorAll('[id^="bec-map-svg-"]').forEach(function (s) {
        s.id = 'bec-map-svg-' + n;
        while (s.firstChild) s.removeChild(s.firstChild);
      });
      clone.querySelectorAll('[id^="bec_tgt_hint_"]').forEach(function (h) {
        var m = h.getAttribute('id').replace(/^bec_tgt_hint_\d+/, 'bec_tgt_hint_' + n);
        h.setAttribute('id', m);
        h.textContent = '\u2190 \u2014';
      });
      var ti = clone.querySelector('[data-role="title"]');
      if (ti) ti.value = 'Feldzuordnung ' + (n + 1);
      var tbody = clone.querySelector('[data-role="cond-table"] tbody');
      if (tbody) {
        tbody.innerHTML = '';
        var tr = document.createElement('tr');
        tr.innerHTML =
          '<td><span class="muted">—</span></td>' +
          '<td><select class="bec-cond-field">' +
          (first.querySelector('.bec-cond-field') ? first.querySelector('.bec-cond-field').innerHTML : '') +
          '</select></td>' +
          '<td><select class="bec-cond-op">' +
          (first.querySelector('.bec-cond-op') ? first.querySelector('.bec-cond-op').innerHTML : '') +
          '</select></td>' +
          '<td><input type="text" class="bec-cond-val" placeholder="Zahl oder Text" /></td>' +
          '<td><button type="button" class="button secondary small bec-cond-del" disabled>−</button></td>';
        tbody.appendChild(tr);
      }
      state.blocks.push({
        id: 'block-' + (n + 1),
        title: 'Feldzuordnung ' + (n + 1),
        conditions: [],
        fieldMapping: JSON.parse(JSON.stringify(defMap || {}))
      });
      Object.keys(state.blocks[n].fieldMapping || {}).forEach(function (k) {
        var hint = clone.querySelector('#bec_tgt_hint_' + n + '_' + k);
        if (hint) {
          var v = state.blocks[n].fieldMapping[k];
          hint.textContent = '\u2190 ' + (v || '\u2014');
        }
      });
      root.appendChild(clone);
      wireConditionUi(clone);
      var wrap = clone.querySelector('.bec-map-wrap');
      if (wrap) initOneBlock(wrap, n);
    });
  }

  var resetAll = document.getElementById('bec-map-reset-all');
  if (resetAll && defNode) {
    resetAll.addEventListener('click', function () {
      try {
        var def = JSON.parse(defNode.textContent || '{}');
        root.querySelectorAll('.bec-map-wrap').forEach(function (wrap) {
          var bi = Number(wrap.getAttribute('data-bec-block-index'));
          if (!state.blocks[bi]) state.blocks[bi] = { fieldMapping: {} };
          state.blocks[bi].fieldMapping = JSON.parse(JSON.stringify(def));
          Object.keys(def).forEach(function (k) {
            var hint = document.getElementById('bec_tgt_hint_' + bi + '_' + k);
            if (hint) hint.textContent = '\u2190 ' + (def[k] || '\u2014');
          });
          if (typeof mapRefreshers[bi] === 'function') mapRefreshers[bi]();
        });
      } catch (e3) { /* ignore */ }
    });
  }

  function pushJsonToForm() {
    if (!jsonOut) return;
    var blocks = serializeFmb();
    jsonOut.value = JSON.stringify(blocks);
  }

  if (form) {
    form.addEventListener('submit', function () {
      pushJsonToForm();
    });
    pushJsonToForm();
  }
})();

(function () {
  var raw = document.getElementById('bec-protocol-json');
  if (!raw) return;
  var list;
  try {
    list = JSON.parse(raw.textContent || '[]');
  } catch (e) {
    return;
  }
  document.querySelectorAll('.bec-dl-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-id');
      var entry = list.find(function (x) { return x.id === id; });
      if (!entry) return;
      var text = (entry.log || '').replace(/\r/g, '');
      var blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
      var a = document.createElement('a');
      var safe = String(entry.type || 'log').replace(/[^a-z0-9_-]/gi, '_');
      a.download = 'apinterface-bec-' + safe + '-' + String(id).replace(/[^a-z0-9_-]/gi, '') + '.txt';
      a.href = URL.createObjectURL(blob);
      a.click();
      setTimeout(function () { URL.revokeObjectURL(a.href); }, 1500);
    });
  });
})();
</script>
